CXX_STD = CXX17

# Compatibility shim for evolving R C-API declarations.
PKG_CPPFLAGS = -include matrixCorr_r_api_compat.h

# Use OpenMP flags for C++
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) -DARMA_USE_CURRENT

# Use matching OpenMP linker flags for C++
PKG_LIBS = $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) $(SHLIB_OPENMP_CXXFLAGS)

-include Makevars.libatomic
